# Server
PORT=4000
NODE_ENV=development

# Auth (shared with editor)
JWT_SECRET=your-better-auth-secret

# Database (same as editor)
DATABASE_URL=postgresql://user:pass@localhost:5432/openvideo

# Redis (Upstash-compatible)
REDIS_URL=redis://localhost:6379

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx

# Google AI
GOOGLE_API_KEY=your-gemini-api-key

# ElevenLabs (sound generation for background music & SFX)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=openvideo-assets
R2_PUBLIC_URL=https://pub-xxx.r2.dev
