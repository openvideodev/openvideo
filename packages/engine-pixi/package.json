{
  "name": "@openvideo/engine-pixi",
  "version": "1.1.3",
  "description": "Video rendering and processing library",
  "keywords": [
    "mp4",
    "rendering",
    "video",
    "webcodecs"
  ],
  "license": "MIT",
  "author": "OpenVideoDev",
  "repository": {
    "type": "git",
    "url": "https://github.com/openvideodev/openvideo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.umd.cjs",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "test": "pnpm exec vitest",
    "test:browser": "pnpm exec vitest run --project unit-chromium",
    "build": "pnpm exec vite build"
  },
  "dependencies": {
    "@openvideo/core": "workspace:*",
    "@pixi/layout": "^3.2.0",
    "@types/dom-webcodecs": "^0.1.17",
    "gl-transitions": "^1.43.0",
    "gsap": "^3.12.7",
    "mediabunny": "^1.26.0",
    "microdiff": "^1.4.0",
    "nanoid": "^5.0.7",
    "opfs-tools": "^0.7.2",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.14.3",
    "typescript": "~5.9.2",
    "wave-resampler": "^1.0.0",
    "wrapbox": "^0.1.0"
  },
  "devDependencies": {
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^27.4.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
