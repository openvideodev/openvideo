{
  "name": "@openvideo/timeline",
  "version": "1.1.3",
  "keywords": [
    "mp4",
    "rendering",
    "video",
    "webcodecs"
  ],
  "license": "MIT",
  "author": "OpenVideoDev",
  "repository": {
    "type": "git",
    "url": "https://github.com/openvideodev/openvideo.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.umd.cjs",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "pnpm exec tsc && pnpm exec vite build",
    "lint": "pnpm exec eslint . --max-warnings 0",
    "format": "pnpm exec prettier --write ."
  },
  "dependencies": {
    "@openvideo/core": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.24",
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "fabric": "^6.3.0",
    "immer": "^10.1.1",
    "lodash-es": "^4.17.21",
    "microdiff": "^1.4.0",
    "nanoid": "^5.0.7",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4"
  }
}
