{
  "name": "@openvideo/db",
  "version": "0.1.0",
  "private": true,
  "description": "Shared database schema and connection for OpenVideo",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./dist/schema/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:fix": "node -e \"require('pg').Client.prototype.query.apply(new (require('pg').Client)({connectionString: process.env.DATABASE_URL}), ['DROP TABLE IF EXISTS langchain_pg_embedding CASCADE; DROP TABLE IF EXISTS langchain_pg_collection CASCADE;']).then(() => console.log('✅ Dropped old LangChain tables')).catch(e => console.error(e))\"",
    "check-types": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10"
  }
}
