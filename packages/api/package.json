{
  "name": "@openvideo/api",
  "version": "0.1.0",
  "private": true,
  "description": "tRPC API for OpenVideo - type-safe backend API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/root.d.ts",
      "import": "./dist/root.js"
    },
    "./trpc": {
      "types": "./dist/trpc.d.ts",
      "import": "./dist/trpc.js"
    },
    "./handler": {
      "types": "./dist/handler.d.ts",
      "import": "./dist/handler.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "check-types": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@openvideo/auth": "workspace:*",
    "@openvideo/db": "workspace:*",
    "@trpc/server": "^11.0.0",
    "@types/node": "^20",
    "bullmq": "^5.51.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "modal": "^0.7.6",
    "superjson": "^2.2.2",
    "typescript": "~5.9.2",
    "zod": "^4.1.13"
  }
}
