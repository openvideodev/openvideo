{
  "name": "@openvideo/core",
  "version": "1.1.3",
  "description": "Core state management and logic for OpenVideo",
  "keywords": [
    "mp4",
    "rendering",
    "video",
    "webcodecs"
  ],
  "license": "MIT",
  "author": "OpenVideoDev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openvideodev/openvideo.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.umd.cjs",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "pnpm exec tsc && pnpm exec vite build",
    "test": "pnpm exec vitest"
  },
  "dependencies": {
    "@types/lodash-es": "^4.17.12",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.0.7",
    "typescript": "~5.9.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "vite": "^7.1.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
