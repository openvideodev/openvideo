# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/openvideo

# AI Services
GOOGLE_API_KEY=your_google_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Modal Configuration (optional, for local development)
MODAL_TOKEN=your_modal_token_here
MODAL_WORKSPACE=your_workspace_name

# R2/Cloudflare Storage (for conformed video uploads)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=openvideo
