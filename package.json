{
  "name": "combo",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=4096' turbo run build --concurrency=1",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter=\"@openvideo/*\" && changeset publish",
    "build:packages": "NODE_OPTIONS='--max-old-space-size=4096' turbo run build --filter='@openvideo/*' --concurrency=1",
    "build:editor-packages": "NODE_OPTIONS='--max-old-space-size=4096' turbo run build --filter='@openvideo/timeline' --filter='@openvideo/engine-pixi' --filter='@openvideo/ai' --filter='@openvideo/core' --concurrency=1",
    "publish:editor-packages": "pnpm build:editor-packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.51.0",
    "oxlint": "^0.16.8",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs,cjs}": [
      "oxlint",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.8",
      "@types/react-dom": "19.2.3",
      "canvas": "3.2.3"
    }
  }
}
